# Ignore node_modules directory
node_modules

# Ignore build output directory (Docker will build it)
dist

# Ignore .env file (should be handled at runtime or via build args if necessary)
.env*

# Ignore Docker artifacts
Dockerfile
.dockerignore
nginx.conf

# Ignore Git directory
.git

# Ignore OS-specific files
.DS_Store
Thumbs.db

# Ignore editor/IDE specific files
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Ignore logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Ignore test reports
coverage/
.nyc_output/ 